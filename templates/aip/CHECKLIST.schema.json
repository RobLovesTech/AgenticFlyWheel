{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Implementation Packet Checklist Schema",
  "type": "object",
  "required": ["version", "feature", "status", "phases"],
  "properties": {
    "version": {"type": "integer", "minimum": 1},
    "feature": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["pending", "in_progress", "blocked", "completed", "abandoned", "incomplete"]},
    "constraints": {"type": "array", "items": {"type": "string"}},
    "parity": {"type": "object"},
    "env_defaults": {"type": "object"},
    "phases": {
      "type": "array",
      "minItems": 1,
      "contains": {
        "type": "object",
        "properties": {
          "id": {"const": "handoff"},
          "name": {"type": "string"},
          "tasks": {
            "type": "array",
            "allOf": [
              {"contains": {"type": "object", "properties": {"id": {"const": "build-verify"}}, "required": ["id"]}},
              {"contains": {"type": "object", "properties": {"id": {"const": "implementation-audit"}}, "required": ["id"]}},
              {"contains": {"type": "object", "properties": {"id": {"const": "audit-remediation"}}, "required": ["id"]}},
              {"contains": {"type": "object", "properties": {"id": {"const": "audit-reverify"}}, "required": ["id"]}},
              {"contains": {"type": "object", "properties": {"id": {"const": "packet-closure"}}, "required": ["id"]}}
            ]
          }
        },
        "required": ["id", "tasks"]
      },
      "allOf": [
        {
          "contains": {
            "type": "object",
            "properties": {
              "tasks": {
                "type": "array",
                "contains": {
                  "type": "object",
                  "properties": {"id": {"const": "collaboration-readiness"}},
                  "required": ["id"]
                }
              }
            },
            "required": ["tasks"]
          }
        }
      ],
      "items": {
        "type": "object",
        "required": ["id", "name", "tasks"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "description": {"type": "string"},
          "tasks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "title", "status"],
              "properties": {
                "id": {"type": "string"},
                "title": {"type": "string"},
                "acceptance": {"type": "array", "items": {"type": "string"}},
                "files": {"type": "array", "items": {"type": "string"}},
                "status": {"type": "string", "enum": ["pending", "in_progress", "blocked", "completed", "abandoned", "incomplete"]}
              }
            }
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "properties": {
        "commands": {"type": "array", "items": {"type": "string"}},
        "acceptance": {"type": "array", "items": {"type": "string"}}
      }
    }
  },
  "description": "Full AIP checklists must include collaboration readiness, REVIEWS.md coverage, and a Docs & Handoff phase with verification, implementation audit, remediation, re-verification, and packet closure gates. Completed collaboration readiness requires user-confirmed Collaboration Summary evidence or an explicit direct/template-only scaffold exception; inferred assumptions alone are insufficient."
}
